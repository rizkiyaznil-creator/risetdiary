# Salin file ini menjadi `.env`, lalu isi nilainya.

# Koneksi PostgreSQL. Cara termudah (gratis): buat project di https://neon.tech
# lalu salin "connection string"-nya ke sini.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Kunci rahasia token session. Buat nilai acak sendiri:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="ganti-dengan-nilai-acak"
