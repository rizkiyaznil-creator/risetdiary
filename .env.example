# Salin file ini menjadi `.env`, lalu sesuaikan bila perlu.
# SQLite: database berupa satu file lokal untuk pengembangan.
DATABASE_URL="file:./dev.db"

# Kunci rahasia token session. Buat nilai acak sendiri:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="ganti-dengan-nilai-acak"
